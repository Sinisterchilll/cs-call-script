# Copy to .env and fill in. Never commit .env.
# Variable names match scripts and .github/workflows/*.

# Postgres (transaction pooler :6543 for app; session :5432 for DDL migration)
DATABASE_URL=
# Optional: session pooler URL for scripts/apply_cdr_source_migration.py only
DATABASE_URL_MIGRATION=

# Tata Tele — scripts/fetch_calls.py
TATA_TELE_API_KEY_INBOUND=
TATA_TELE_API_KEY_OUTBOUND=

# Ozonetel — scripts/fetch_ozonetel_calls.py
OZONETEL_API_KEY=
OZONETEL_USERNAME=
# OZONETEL_DOMAIN=in1-ccaas-api.ozonetel.com

# Analysis — scripts/analyze_calls.py
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Weekly eval — scripts/eval_generate.py, eval_score.py (GitHub: secrets)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# GOOGLE_CREDENTIALS_JSON in CI; locally use file:
# GOOGLE_CREDENTIALS_FILE=google-credentials.json
SHEET_ID_PRUDHVI=
SHEET_ID_AUM=
SHEET_ID_AYUSH=
SHEET_ID_SWARNA=
SHEET_ID_UDITI=
SHEET_ID_SCORES=

# Optional — Ozonetel incremental tail overlap (minutes)
# OZONETEL_INCREMENTAL_OVERLAP_MINUTES=3
